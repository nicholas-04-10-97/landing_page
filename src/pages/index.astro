---
import Layout from '../layout/GlobalLayout.astro';

const carros = [
  {
    titulo: "Sedãs Premium",
    descricao: "Conforto, tecnologia e desempenho para quem busca elegância em cada viagem.",
    imagem: "https://images.unsplash.com/photo-1503376780353-7e6692767b70?w=600"
  },
  {
    titulo: "SUVs",
    descricao: "Espaço, segurança e potência para toda a família.",
    imagem: "https://images.unsplash.com/photo-1552519507-da3b142c6e3d?w=600"
  },
  {
    titulo: "Esportivos",
    descricao: "Performance e design para quem gosta de emoção ao dirigir.",
    imagem: "https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?w=600"
  }
];
---
<Layout title="Carros dos Sonhos">
<body>

    <!-- Hero -->
    <section class="secao-hero">

        <div class="conteudo-hero">
            <h1>Encontre o carro dos seus sonhos</h1>

            <p>
                Veículos novos e seminovos com garantia, financiamento facilitado
                e as melhores condições do mercado.
            </p>

            <a href="#carros" class="botao-principal">
                Ver ofertas
            </a>
        </div>

    </section>

    <!-- Cards -->
    <section class="secao-carros" id="carros">

        <h2>Nossos Destaques</h2>

        <div class="grade-carros">

            {
                carros.map((carro) => (

                    <article class="card-carro">

                        <img
                            src={carro.imagem}
                            alt={carro.titulo}
                        />

                        <div class="conteudo-card">

                            <h3>{carro.titulo}</h3>

                            <p>{carro.descricao}</p>

                            <button>
                                Saiba mais
                            </button>

                        </div>

                    </article>

                ))
            }

        </div>

    </section>
    <!-- Sobre Nós -->

<section class="secao-sobre" id="saiba-mais">

    <div class="conteudo-sobre">

        <div class="texto-sobre">

            <span class="titulo-pequeno">
                Sobre Nós
            </span>

            <h2>
                Há mais de 20 anos conectando pessoas ao carro ideal.
            </h2>

            <p>
                A Auto Prime oferece veículos novos e seminovos de diversas
                marcas, sempre priorizando qualidade, segurança e transparência
                em cada negociação. Nossa equipe está preparada para ajudar
                você a encontrar o automóvel perfeito para suas necessidades.
            </p>

        </div>

        <div class="informacoes-contato">

            <div class="item-contato">

                <h3>Endereço</h3>

                <p>
                    Av. das Nações, 1250<br>
                    Centro - São Paulo/SP<br>
                    CEP 01000-000
                </p>

            </div>

            <div class="item-contato">

                <h3>Telefone</h3>

                <p>
                    (11) 4000-1234
                </p>

            </div>

            <div class="item-contato">

                <h3>E-mail</h3>

                <p>
                    contato@autoprime.com.br
                </p>

            </div>

            <div class="item-contato">

                <h3>Horário de Atendimento</h3>

                <p>
                    Segunda a Sexta<br>
                    08:00 às 18:00
                </p>

            </div>

        </div>

    </div>

</section>

</body>
</Layout>